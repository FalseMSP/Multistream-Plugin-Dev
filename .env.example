# ─── Discord ──────────────────────────────────────────────────────────────────
# Webhook for regular chat messages (Twitch + YouTube)
DISCORD_CHAT_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_CHAT_WEBHOOK

# Webhook for Twitch channel point redeems (separate channel)
DISCORD_REDEEM_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_REDEEM_WEBHOOK

# Bot token — required for /ban /vip slash commands
# Create at: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your-bot-token-here

# Application (client) ID from Discord Developer Portal
DISCORD_CLIENT_ID=your-client-id-here

# Guild (server) ID — right-click your server → Copy Server ID
DISCORD_GUILD_ID=your-guild-id-here

# Max Discord messages per second (default: 2)
DISCORD_RATE_LIMIT=2

# ─── Twitch ───────────────────────────────────────────────────────────────────
# OAuth token for the bot account: https://twitchapps.com/tmi/
TWITCH_TOKEN=oauth:your-token-here

# Client ID + Secret from https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=your-client-id
TWITCH_CLIENT_SECRET=your-client-secret

# The bot account's username
TWITCH_BOT_NICK=your_bot_username

# Comma-separated list of channels to monitor
TWITCH_CHANNELS=channel1,channel2

# The broadcaster's login (for mod actions via Helix API)
# Defaults to the first channel in TWITCH_CHANNELS if not set
TWITCH_BROADCASTER_LOGIN=broadcaster_username

# ─── YouTube ──────────────────────────────────────────────────────────────────
# YouTube Data API v3 key: https://console.cloud.google.com/
YT_API_KEY=your-api-key-here

# Channel ID (UCxxxx...) — used for WebSub and live video detection
YT_CHANNEL_ID=UCyour-channel-id

# Optional: hardcode a video ID to always mirror (skips live detection)
# YT_VIDEO_ID=

# Polling interval in seconds when WebSub is not configured (default: 30)
YT_POLL_INTERVAL=30

# ─── WebSub (YouTube push notifications) ─────────────────────────────────────
# Your server's public HTTPS URL. Leave blank to use polling instead.
# Example: https://yourdomain.com
WEBSUB_PUBLIC_URL=

# HMAC secret for verifying WebSub payloads — change this!
WEBSUB_SECRET=change-me-to-something-random

# Port the WebSub HTTP server listens on (default: 8081)
WEBSUB_PORT=8081

# ─── Logging ──────────────────────────────────────────────────────────────────
# debug | info | warn | error  (default: info)
LOG_LEVEL=info
